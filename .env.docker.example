# Copy values from this file into your shell environment or a local .env file before docker compose up.
POSTGRES_DB=content_pipeline
POSTGRES_USER=content_pipeline
POSTGRES_PASSWORD=change-me
APP_PORT=5000

# External source database used by /api/materials/pull_recent.
# Leave empty if you do not need to pull materials from the mini-program database.
# Example: mysql+pymysql://pipeline_reader:replace-with-password@81.68.133.54:3306/shangying_mvp?charset=utf8mb4
DATABASE_URL=

CONTENT_LLM_API_KEY=
CONTENT_LLM_BASE_URL=https://api.openai.com/v1
CONTENT_LLM_MODEL=gpt-4o-mini
CONTENT_LLM_MOCK=false

CELERY_WORKER_CONCURRENCY=2
APP_DB_POOL_SIZE=5
APP_DB_MAX_OVERFLOW=10
APP_DB_POOL_RECYCLE_SECONDS=1800
SCHEDULER_ENABLED=false
